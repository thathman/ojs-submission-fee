msgid ""
msgstr ""
"Project-Id-Version: submissionFee\n"
"Language: en\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "plugins.generic.submissionFee.displayName"
msgstr "Submission Fee"

msgid "plugins.generic.submissionFee.description"
msgstr "Charges a fee at submission time, collected via the journal's configured payment method."

msgid "plugins.generic.submissionFee.settings.enabled"
msgstr "Enable the submission fee for this journal"

msgid "plugins.generic.submissionFee.settings.amount"
msgstr "Fee amount"

msgid "plugins.generic.submissionFee.settings.amount.invalid"
msgstr "The fee amount must be a number greater than zero."

msgid "plugins.generic.submissionFee.settings.currency"
msgstr "Currency code (e.g. NGN, USD)"

msgid "plugins.generic.submissionFee.settings.mode"
msgstr "Enforcement"

msgid "plugins.generic.submissionFee.settings.mode.hardBlock"
msgstr "Hard block: author cannot complete the submission until the fee is paid"

msgid "plugins.generic.submissionFee.settings.mode.holdUntilPaid"
msgstr "Hold until paid: submission completes but is flagged for the editor until the fee is paid"

msgid "plugins.generic.submissionFee.error.unpaid"
msgstr "A submission fee is required before you can complete this submission. Please pay here: {$url}"

msgid "plugins.generic.submissionFee.outstanding"
msgstr "Submission fee outstanding"

msgid "plugins.generic.submissionFee.notice.title"
msgstr "Submission fee"

msgid "plugins.generic.submissionFee.notice.amount"
msgstr "A fee of {$amount} {$currency} applies to this submission."

msgid "plugins.generic.submissionFee.notice.bodyHardBlock"
msgstr "Payment is required before you can complete this submission. Use the button below to pay; you can return here and submit once payment is confirmed."

msgid "plugins.generic.submissionFee.notice.bodyHoldUntilPaid"
msgstr "You can complete this submission now, but it will be held for editorial processing until this fee is paid. You may pay now using the button below."

msgid "plugins.generic.submissionFee.notice.payNow"
msgstr "Pay submission fee"

msgid "plugins.generic.submissionFee.notice.paid"
msgstr "Payment received — thank you. You may now continue with your submission."

msgid "plugins.generic.submissionFee.settings.noticePlacement"
msgstr "Show the fee notice on these wizard steps"

msgid "plugins.generic.submissionFee.settings.steps.details"
msgstr "Details"

msgid "plugins.generic.submissionFee.settings.steps.files"
msgstr "Upload Files"

msgid "plugins.generic.submissionFee.settings.steps.contributors"
msgstr "Contributors"

msgid "plugins.generic.submissionFee.settings.steps.editors"
msgstr "For the Editors"

msgid "plugins.generic.submissionFee.settings.steps.reviewerSuggestions"
msgstr "Reviewer Suggestions (when enabled)"

msgid "plugins.generic.submissionFee.settings.steps.review"
msgstr "Review (final step)"

msgid "plugins.generic.submissionFee.settings.otherSurfaces"
msgstr "Also show the fee"

msgid "plugins.generic.submissionFee.settings.ownStep"
msgstr "As its own \"Payment\" step in the wizard, just before Review"

msgid "plugins.generic.submissionFee.settings.showOnStart"
msgstr "On the \"Begin a Submission\" page (informational, before the wizard)"

msgid "plugins.generic.submissionFee.settings.showOnComplete"
msgstr "On the submission-complete (confirmation) page, with a Pay button"

msgid "plugins.generic.submissionFee.step.name"
msgstr "Payment"

msgid "plugins.generic.submissionFee.settings.noticeTitle"
msgstr "Notice title (leave blank for the default)"

msgid "plugins.generic.submissionFee.settings.noticeBodyHardBlock"
msgstr "Notice message — hard-block mode (leave blank for the default)"

msgid "plugins.generic.submissionFee.settings.noticeBodyHoldUntilPaid"
msgstr "Notice message — hold-until-paid mode (leave blank for the default)"

msgid "mailable.submissionFeeRequired.name"
msgstr "Submission Fee Required"

msgid "mailable.submissionFeeRequired.description"
msgstr "Sent to the submitting author when their submission is received with the submission fee still outstanding."

msgid "emails.submissionFeeRequired.subject"
msgstr "Submission fee required for your submission"

msgid "emails.submissionFeeRequired.body"
msgstr "<p>Dear {$recipientName},</p><p>Thank you for your submission, \"{$submissionTitle}\". A submission fee of <strong>{$submissionFeeAmount} {$submissionFeeCurrency}</strong> applies and is still outstanding. Your submission will be held for editorial processing until the fee is paid.</p><p><a href=\"{$submissionFeePayUrl}\">Pay the submission fee</a></p><p>{$journalSignature}</p>"

msgid "plugins.generic.submissionFee.emailVar.submissionTitle"
msgstr "The title of the submission."

msgid "plugins.generic.submissionFee.emailVar.amount"
msgstr "The submission fee amount."

msgid "plugins.generic.submissionFee.emailVar.currency"
msgstr "The submission fee currency code."

msgid "plugins.generic.submissionFee.emailVar.payUrl"
msgstr "The URL where the author can pay the submission fee."